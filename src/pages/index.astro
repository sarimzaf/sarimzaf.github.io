---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About">
  <div class="about-grid">
    <div class="about-text">
      <h1>Sarim Zafar</h1>
      <p class="subtitle">
        Research Analyst,
        <a href="https://www.ifpri.org" target="_blank" rel="noopener">IFPRI</a>
        &nbsp;·&nbsp; Washington, DC
      </p>

      <p>
        I work in the Poverty, Gender and Inclusion department at the
        International Food Policy Research Institute (IFPRI), where I support
        research on education, cash transfers, and mental health.
      </p>

      <p>
        My research interests are in applied microeconomics and behavioral
        economics — particularly individual decision-making, preferences, and
        the economics of poverty.
      </p>

      <p>
        I hold a Masters of Research in Economics from the
        <a href="https://www.parisschoolofeconomics.eu" target="_blank" rel="noopener">
          Paris School of Economics
        </a>
        and an undergraduate degree from
        <a href="https://www.lums.edu.pk" target="_blank" rel="noopener">
          Lahore University of Management Sciences (LUMS)
        </a>.
      </p>

      <div class="contact-links">
        <a href="mailto:sarimzafar25@gmail.com">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
          Email
        </a>
        <a href="https://linkedin.com/in/sarim-zaf" target="_blank" rel="noopener">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect width="4" height="12" x="2" y="9"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
          LinkedIn
        </a>
        <!-- Add CV / Google Scholar links here when ready -->
      </div>
    </div>

    <div class="profile-photo-placeholder" aria-label="Profile photo placeholder">
      Photo
    </div>
  </div>

  <div class="home-section">
    <h2 class="section-heading">Research Interests</h2>
    <ul class="interests-list">
      <li>Applied Microeconomics</li>
      <li>Behavioral Economics</li>
      <li>Poverty &amp; Inequality</li>
      <li>Education</li>
      <li>Cash Transfers</li>
      <li>Mental Health &amp; Well-being</li>
    </ul>
  </div>

  <div class="home-section">
    <h2 class="section-heading">Education</h2>
    <ul class="education-list">
      <li>
        <span class="edu-year">2023</span>
        <div>
          <div class="edu-degree">Masters of Research in Economics</div>
          <div class="edu-school">Paris School of Economics</div>
        </div>
      </li>
      <li>
        <span class="edu-year">2021</span>
        <div>
          <div class="edu-degree">BSc Economics <!-- update degree name if needed --></div>
          <div class="edu-school">Lahore University of Management Sciences (LUMS)</div>
        </div>
      </li>
    </ul>
  </div>
</Layout>
